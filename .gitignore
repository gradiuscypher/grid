# Berkeley Mono — commercially licensed, not redistributable (see docs/ARCHITECTURE.md §8).
# Supply locally; the theme's fallback font stack covers machines without it.
berkeley-mono-web/
frontend/public/fonts/BerkeleyMono*

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# Node
node_modules/
dist/
dist-ssr/
.vite/
coverage/

# Playwright
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/

# Regenerated by `make api-client` (backend/Makefile's openapi-schema target
# dumps this fresh each time) — the generated TS client itself is committed.
frontend/openapi.json

# Env files
.env
.env.*
!.env.example

# Editors / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store

# Temporal / misc local state
*.log

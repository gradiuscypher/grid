# Grid — environment configuration
#
# Copy to .env (gitignored) and adjust. Every value here has a dev-safe default
# baked into deploy/compose.dev.yaml, so a fresh clone works without a .env at all —
# this file documents what exists and what prod must override.

# --- Postgres (db service; also used by api, worker, temporal) ---
POSTGRES_USER=grid
POSTGRES_PASSWORD=grid
POSTGRES_DB=grid

# --- Coming in later phases (documented early so names are stable) ---
# Phase 1: session signing, API base settings (pydantic-settings)
# GRID_SECRET_KEY=
# Phase 3: Fernet key for credential vault (transform/LLM creds at rest)
# GRID_CREDENTIAL_KEY=
